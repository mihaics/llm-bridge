# llm-bridge as a PER-USER systemd service (systemctl --user) — runs as you, in your user
# session, so it inherits XDG_RUNTIME_DIR + DBUS_SESSION_BUS_ADDRESS (agy's OS keyring) and your
# claude/codex file logins. Do NOT install this as a system service (/etc/systemd/system): a system
# service has neither your keyring/D-Bus session nor your home logins.
#
# Install:
#   cargo build --release
#   cp deploy/config.example.yaml deploy/config.yaml   # edit token + cred dirs (if not done already)
#   mkdir -p ~/.config/systemd/user
#   cp deploy/llm-bridge.service ~/.config/systemd/user/
#   #  -> edit WorkingDirectory / ExecStart paths and the fnm node-bin in PATH (see below)
#   systemctl --user daemon-reload
#   systemctl --user enable --now llm-bridge
#   loginctl enable-linger "$USER"            # keep it running when you're not logged in
#   journalctl --user -u llm-bridge -f        # follow logs

[Unit]
Description=llm-bridge — OpenAI-compatible shim over local agent CLIs (claude/codex/agy)
After=default.target

[Service]
Type=simple
# %h = your home dir. Adjust these to your checkout location:
WorkingDirectory=%h/src/llm-bridge
ExecStart=%h/src/llm-bridge/target/release/llm-bridge %h/src/llm-bridge/deploy/config.yaml

# claude + agy live in ~/.local/bin. codex is a Node script whose `which` path is an EPHEMERAL
# per-shell fnm dir, so pin the STABLE fnm node-version bin (it also provides the `node` codex needs).
# Find yours:   ls -d ~/.local/share/fnm/node-versions/*/installation/bin
# If you don't use codex, you can drop that entry (claude + agy only need ~/.local/bin).
Environment=PATH=%h/.local/bin:%h/.local/share/fnm/node-versions/<NODE_VERSION>/installation/bin:/usr/local/bin:/usr/bin:/bin

Restart=on-failure
RestartSec=2

[Install]
WantedBy=default.target
